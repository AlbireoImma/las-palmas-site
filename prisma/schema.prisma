generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: SQLite doesn't support native enums in Prisma v5.
// Enum values are enforced at the TypeScript level (see src/types/enums.ts).
// Fields use String type with semantic names.

// ─── NextAuth required tables ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ─────────────────────────────────────────────────────────────

// role: INVITADO | JUGADOR | SOCIO | ADMINISTRADOR
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("INVITADO")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  player   Player?
}

// category: PRIMERA | SEGUNDA | SENIOR
model Player {
  id          String    @id @default(cuid())
  userId      String    @unique
  firstName   String
  lastName    String
  dorsal      Int?
  position    String?
  category    String
  dateOfBirth DateTime?
  phone       String?
  joinedAt    DateTime  @default(now())
  isActive    Boolean   @default(true)
  photoUrl    String?
  bio         String?
  updatedAt   DateTime  @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchStats    MatchPlayerStat[]
  lineupEntries LineupEntry[]
  attendances   EventAttendance[]
}

// type: PARTIDO | ENTRENAMIENTO | REUNION | OTRO
// category: PRIMERA | SEGUNDA | SENIOR | null (all)
model Event {
  id          String    @id @default(cuid())
  title       String
  type        String
  date        DateTime
  location    String?
  description String?
  isPublic    Boolean   @default(true)
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  match       Match?
  lineup      Lineup?
  attendances EventAttendance[]
}

// result: VICTORIA | EMPATE | DERROTA | null (pending)
model Match {
  id           String  @id @default(cuid())
  eventId      String  @unique
  opponentName String
  isHome       Boolean @default(true)
  goalsFor     Int?
  goalsAgainst Int?
  result       String?
  notes        String?

  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  playerStats MatchPlayerStat[]
}

model MatchPlayerStat {
  id            String  @id @default(cuid())
  matchId       String
  playerId      String
  minutesPlayed Int     @default(0)
  goals         Int     @default(0)
  assists       Int     @default(0)
  isCaptain     Boolean @default(false)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  cards  Card[]

  @@unique([matchId, playerId])
}

// type: AMARILLA | ROJA | DOBLE_AMARILLA
model Card {
  id     String  @id @default(cuid())
  statId String
  type   String
  minute Int?

  stat MatchPlayerStat @relation(fields: [statId], references: [id], onDelete: Cascade)
}

model Lineup {
  id        String   @id @default(cuid())
  eventId   String   @unique
  formation String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entries LineupEntry[]
}

model LineupEntry {
  id        String  @id @default(cuid())
  lineupId  String
  playerId  String
  position  String?
  isStarter Boolean @default(true)
  order     Int?

  lineup Lineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([lineupId, playerId])
}

model EventAttendance {
  id        String   @id @default(cuid())
  eventId   String
  playerId  String
  confirmed Boolean  @default(false)
  attended  Boolean?
  note      String?
  updatedAt DateTime @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

// category: PRIMERA | SEGUNDA | SENIOR
model TeamSeason {
  id           String   @id @default(cuid())
  category     String
  season       String
  wins         Int      @default(0)
  draws        Int      @default(0)
  losses       Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  points       Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([category, season])
}
